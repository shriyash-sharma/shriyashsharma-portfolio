APP_ENV=development
APP_NAME="Portfolio API"
API_VERSION=v1
FRONTEND_ORIGIN=http://localhost:3000

# Local Docker Postgres (see docker-compose.yml). Never commit real credentials.
# For Supabase or other remote DBs, set DATABASE_URL here or in docker-compose.override.yml
# (gitignored). For Supabase use:
# postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# Passwords with @ are supported (parsed from the last @ before the host).
# If SSL fails on a corporate network during local migrations only:
# DATABASE_SSL_INSECURE=1
DATABASE_URL=postgresql+asyncpg://portfolio:portfolio@localhost:5433/portfolio

# Auth (required in production — do not use defaults)
ADMIN_JWT_SECRET=change-me-before-production
ADMIN_BOOTSTRAP_EMAIL=admin@localhost
ADMIN_BOOTSTRAP_PASSWORD=changeme-admin-password
ADMIN_BOOTSTRAP_NAME=Platform Admin
ADMIN_SESSION_TTL_MINUTES=720

# Local media uploads (ephemeral on Render — use object storage in production)
MEDIA_STORAGE_PATH=./storage/media
MEDIA_PUBLIC_URL_BASE=/media

# Future integrations (not used yet)
REDIS_URL=
AI_PROVIDER_API_KEY=

# --- AI / RAG assistant ---------------------------------------------------
# Embeddings (OpenAI) — required for ingestion and retrieval.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Chat LLM — Groq is the default; switch LLM_PROVIDER=openai to use OpenAI.
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=700
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Retrieval tuning
RAG_TOP_K=6
RAG_MIN_SIMILARITY=0.15
RAG_MAX_CONTEXT_CHARS=6000
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
# Over-fetch candidate chunks (top_k * multiplier) before applying the
# per-document cap, so one long document cannot fill the whole context.
RAG_CANDIDATE_MULTIPLIER=6
RAG_MAX_CHUNKS_PER_DOCUMENT=3
# HNSW search breadth. Higher = better recall, slightly slower.
RAG_HNSW_EF_SEARCH=200

# Public assistant — max requests per client IP per 60s (0 = disabled)
ASSISTANT_RATE_LIMIT_PER_MINUTE=10
