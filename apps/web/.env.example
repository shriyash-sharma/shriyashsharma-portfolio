# Copy to .env.local for local development.
# On Vercel, set these in Project → Settings → Environment Variables.

# Public HTTPS URL of the FastAPI backend (browser + media asset URLs)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side URL for RSC and /api route handlers (Vercel → Render)
# In production, set to the same public API URL unless using a private network.
API_INTERNAL_URL=http://localhost:8000

# Canonical site URL for SEO (canonical, Open Graph, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
